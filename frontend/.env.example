# ── Frontend — Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── API Gateway URL ───────────────────────────────────────────────────────────
# Development (gateway running locally):
VITE_API_URL=http://localhost:8000

# Production (replace with your Render gateway URL):
# VITE_API_URL=https://futurehr-gateway.onrender.com
