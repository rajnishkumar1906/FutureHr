# ── Auth Service — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── JWT (use the same secret across ALL services) ────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Cookie ───────────────────────────────────────────────────────────────────
# Set to true in production (Render/HTTPS) so cookie is SameSite=None; Secure
# allowing it to be sent cross-origin from Vercel → Render.
# Leave false (default) in local development (HTTP).
COOKIE_SECURE=false
# COOKIE_SECURE=true   ← set this in Render's environment variables

# ── CORS ─────────────────────────────────────────────────────────────────────
# Development:
ALLOWED_ORIGINS=http://localhost:5173

# Production (comma-separated, add your Vercel URL):
# ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
