# ── AI Recruitment Service — Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── AI ───────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-google-gemini-api-key

# ── Auth (must match auth service) ───────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256

# ── Internal service URLs ────────────────────────────────────────────────────
# Development:
AUTH_SERVICE_URL=http://localhost:8001
HRMS_SERVICE_URL=http://localhost:8002

# Production (replace with your Render service URLs):
# AUTH_SERVICE_URL=https://futurehr-auth.onrender.com
# HRMS_SERVICE_URL=https://futurehr-hrms.onrender.com

# ── Frontend URL (used in email links) ───────────────────────────────────────
# Development:
FRONTEND_URL=http://localhost:5173

# Production (replace with your Vercel URL):
# FRONTEND_URL=https://your-app.vercel.app

# ── Email (Gmail SMTP with App Password) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM=your@gmail.com

# ── CORS ─────────────────────────────────────────────────────────────────────
# Development:
ALLOWED_ORIGINS=http://localhost:5173

# Production (comma-separated):
# ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
