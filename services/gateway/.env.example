# ── Gateway Service — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Upstream service URLs ────────────────────────────────────────────────────
# Development (all running locally):
AUTH_SERVICE_URL=http://localhost:8001
HRMS_SERVICE_URL=http://localhost:8002
AI_RECRUITMENT_SERVICE_URL=http://localhost:8003

# Production (replace with your Render service URLs):
# AUTH_SERVICE_URL=https://futurehr-auth.onrender.com
# HRMS_SERVICE_URL=https://futurehr-hrms.onrender.com
# AI_RECRUITMENT_SERVICE_URL=https://futurehr-ai.onrender.com

# ── CORS ─────────────────────────────────────────────────────────────────────
# Development:
ALLOWED_ORIGINS=http://localhost:5173

# Production (add your Vercel URL, comma-separated):
# ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
